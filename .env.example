# ============================================================
# LedgerIQ — docker-compose configuration
# Copy to `.env` (same directory as docker-compose.yml).
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=ledgeriq
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=ledgeriq

# ---- Backend security ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string

# ---- Public origin (used for CORS) ----
PUBLIC_ORIGIN=http://localhost

# ---- Host port the nginx proxy listens on ----
HTTP_PORT=80
