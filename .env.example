# ============================================================
# LedgerIQ — docker-compose configuration
# Copy to `.env` (same directory as docker-compose.yml).
# ============================================================

# ---- PostgreSQL ----
POSTGRES_USER=ledgeriq
POSTGRES_PASSWORD=change_this_password
POSTGRES_DB=ledgeriq

# ---- Backend security ----
# Generate: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string

# ---- Public origin (your site URL; used for CORS) ----
# For the Cloudflare-tunnel deploy, set this to your HTTPS domain:
#   PUBLIC_ORIGIN=https://app.yourdomain.com
PUBLIC_ORIGIN=http://localhost

# ---- Cloudflare Tunnel (only used by docker-compose.tunnel.yml) ----
# Cloudflare Zero Trust -> Networks -> Tunnels -> create a tunnel, copy its
# token here, and point its Public Hostname at service:  http://nginx:80
TUNNEL_TOKEN=

# ---- Host port the nginx proxy listens on ----
# Not needed when using the tunnel (no inbound port required), but handy for
# testing the stack directly on the server.
HTTP_PORT=80

# ---- LLM / AI (optional, server-side only) ----
# Leave LLM_API_KEY empty to use the built-in rule-based AI (zero-config).
# When set, it is passed to the backend container only — never the frontend.
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
