# ============================================================
# LedgerIQ — Backend environment configuration
# Copy to `.env` and adjust. Never commit the real `.env`.
# ============================================================

# ---- Application ----
PROJECT_NAME=LedgerIQ
ENVIRONMENT=local          # local | development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Database ----
# PRIMARY: PostgreSQL. Use a sync-style URL; the app upgrades it to asyncpg.
# Example: postgresql://ledgeriq:ledgeriq@localhost:5432/ledgeriq
# Leave DATABASE_URL empty to fall back to local async SQLite (SQLITE_PATH).
DATABASE_URL=
SQLITE_PATH=./ledgeriq.db
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---- JWT / Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Locale ----
DEFAULT_CURRENCY=INR
DEFAULT_LOCALE=en-IN
DEFAULT_TIMEZONE=Asia/Kolkata
