# ============================================================
# LedgerIQ — Backend environment configuration
# Copy to `.env` and adjust. Never commit the real `.env`.
# ============================================================

# ---- Application ----
PROJECT_NAME=LedgerIQ
ENVIRONMENT=local          # local | development | staging | production
DEBUG=true
API_V1_PREFIX=/api/v1

# ---- Server ----
HOST=0.0.0.0
PORT=8000

# ---- CORS (comma-separated origins) ----
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ---- Database ----
# PRIMARY: PostgreSQL. Use a sync-style URL; the app upgrades it to asyncpg.
# Example: postgresql://ledgeriq:ledgeriq@localhost:5432/ledgeriq
# Leave DATABASE_URL empty to fall back to local async SQLite (SQLITE_PATH).
DATABASE_URL=
SQLITE_PATH=./ledgeriq.db
DB_ECHO=false
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ---- JWT / Security ----
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET=CHANGE_ME_IN_PRODUCTION_use_a_long_random_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Locale ----
DEFAULT_CURRENCY=INR
DEFAULT_LOCALE=en-IN
DEFAULT_TIMEZONE=Asia/Kolkata

# ---- LLM / AI (optional) ----
# Leave LLM_API_KEY empty to use the rule-based AI services (zero-config).
# When set, expense categorization becomes hybrid (rule-first, LLM for the hard
# cases) and insights are generated by the LLM on a weekly schedule.
# The API key MUST stay in this backend .env — never expose it to the frontend.
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-haiku-4-5-20251001
LLM_TIMEOUT_SECONDS=20
LLM_INSIGHTS_ENABLED=true
LLM_INSIGHTS_DAY_OF_WEEK=mon
LLM_INSIGHTS_HOUR=7
LLM_INSIGHTS_PERIOD=monthly
LLM_INSIGHTS_TTL_DAYS=8
